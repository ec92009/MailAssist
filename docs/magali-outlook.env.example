# Magali-ready Outlook setup template.
# Copy these values into the local .env on the Windows test machine after the
# MailAssist Microsoft Entra app registration is created or verified.
# See docs/magali-windows-readiness-runbook.md for the exact Windows sequence.
#
# Do not put tokens, passwords, or private mailbox content in this file.

MAILASSIST_OUTLOOK_ENABLED=true
MAILASSIST_DEFAULT_PROVIDER=outlook

# Use the Application (client) ID from the MailAssist Entra app registration.
# The app registration must support work/school Microsoft 365 accounts.
MAILASSIST_OUTLOOK_CLIENT_ID=<mailassist-entra-application-client-id>

# Prefer the Golden Years tenant id if known. Use "organizations" for the
# first work/school-account device-code check when the tenant id is not known.
MAILASSIST_OUTLOOK_TENANT_ID=organizations

# Keep local tokens under secrets/. This path is ignored by git.
MAILASSIST_OUTLOOK_TOKEN_FILE=secrets/outlook-token.json

# MailAssist checks Ollama through its own client with think:false.
MAILASSIST_OLLAMA_URL=http://localhost:11434
MAILASSIST_OLLAMA_MODEL=qwen3:8b
